generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id              String    @id @default(cuid())
  serviceNo       String    @unique
  name            String
  rankId          String
  rank            Rank      @relation(fields: [rankId], references: [id])
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  cardType        String    // "Ministerial" or "Industrial"
  
  // Extended Details
  appointmentDate DateTime
  joiningCurrentUnitDate DateTime
  appointmentLetterRef String
  joiningLetterRef String
  retirementDate  DateTime
  
  // Addresses
  presentAddress  String
  permanentAddress String
  
  status          String    @default("Active")
  phones          EmployeePhone[]
  letters         EmployeeLetter[]
  
  sanctions       Sanction[]
  workLogs        WorkLog[]
  leaves          Leave[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Rank {
  id              String    @id @default(cuid())
  name            String    @unique
  employees       Employee[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Department {
  id              String    @id @default(cuid())
  name            String    @unique
  location        String
  navcom          String
  hodName         String
  hodRank         String
  bornStrength    Int
  approvedSanctionStrength Int
  employees       Employee[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmployeePhone {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  phoneNumber     String
  imei1           String?
  imei2           String?
  model           String?
  brand           String?
}

model EmployeeLetter {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  referenceNumber String
  referenceDate   DateTime
  fileName        String
  fileNumber      String
}

model Sanction {
  id              String    @id @default(cuid())
  amount          Float
  reason          String
  date            DateTime
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model WorkLog {
  id              String    @id @default(cuid())
  date            DateTime
  hours           Float
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model Leave {
  id              String    @id @default(cuid())
  startDate       DateTime
  endDate         DateTime
  type            String
  status          String    @default("Pending")
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}
