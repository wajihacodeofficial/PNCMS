generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Employee {
  id              String    @id @default(cuid())
  serviceNo       String    @unique
  name            String
  rankId          String
  rank            Rank      @relation(fields: [rankId], references: [id])
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  cardType        String    // "Ministerial" or "Industrial"
  bps             String?
  cnic            String?   @unique
  status          String    @default("Active")
  gender          String?
  fatherName      String?
  dob             String?
  bloodGroup      String?
  domicile        String?
  permanentAddress String?
  presentAddress  String?
  
  // Next of Kin
  nokName         String?
  nokRelation     String?
  nokContact      String?
  nokCnic         String?
  
  // Bank Details
  bankName        String?
  bankAccount     String?
  bankBranch      String?
  accountType     String?
  
  // Service Details
  appointmentDate String?
  joiningCurrentUnitDate String?
  appointmentLetterRef String?
  joiningLetterRef String?
  retirementDate  DateTime?
  lastPromotion   String?
  unitLocation    String?
  
  phones          EmployeePhone[]
  letters         EmployeeLetter[]
  sanctions       Sanction[]
  workLogs        WorkLog[]
  leaves          LeaveRecord[]
  disciplinaryActions DisciplinaryAction[]
  payments        Payment[]
  attendance      Attendance[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Rank {
  id              String    @id @default(cuid())
  name            String    @unique
  cadre           String?   // Ministerial or Industrial
  bps             String?
  employees       Employee[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Department {
  id              String    @id @default(cuid())
  name            String    @unique
  location        String?
  navcom          String?
  hodName         String?
  hodRank         String?
  bornStrength    Int?
  approvedSanctionStrength Int?
  employees       Employee[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmployeePhone {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  phoneNumber     String
  imei1           String?
  imei2           String?
  model           String?
  brand           String?
}

model EmployeeLetter {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  referenceNumber String
  referenceDate   DateTime
  fileName        String
  fileNumber      String
}

model Sanction {
  id              String    @id @default(cuid())
  sanctionId      String    @unique // e.g., SNC-2026-0130
  amount          Float?
  hours           Float?
  period          String?
  reason          String?
  date            String?
  status          String    @default("Pending")
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model WorkLog {
  id              String    @id @default(cuid())
  date            DateTime
  hours           Float
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model LeaveRecord {
  id              String    @id @default(cuid())
  startDate       String
  endDate         String
  type            String
  days            Int
  status          String    @default("Pending")
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model DisciplinaryAction {
  id              String    @id @default(cuid())
  caseId          String    @unique // e.g., CASE-2026-001
  type            String
  offense         String
  action          String
  date            String
  status          String
  remarks         String?
  reference       String?
  details         String?
  authority       String?
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model Payment {
  id              String    @id @default(cuid())
  type            String    // e.g., Late-Sitting, Overtime
  gross           Float
  leave           Float
  payable         Float
  rate            Float
  amount          Float
  status          String
  period          String
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model Attendance {
  id              String    @id @default(cuid())
  date            String
  status          String    // P, A, CL, RL, etc.
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@unique([date, employeeId])
}

model User {
  id              String    @id @default(cuid())
  username        String    @unique
  password        String    // Hashed
  role            String    @default("Clerk") // Admin, Clerk
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Setting {
  id              String    @id @default(cuid())
  key             String    @unique
  value           String
  updatedAt       DateTime  @updatedAt
}

model Log {
  id              String    @id @default(cuid())
  time            DateTime  @default(now())
  user            String
  action          String
  entity          String
  ip              String
  result          String
}
