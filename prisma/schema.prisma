generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Employee {
  serviceNo              String               @id
  name                   String
  phoneNumber            String?
  rankId                 String
  departmentId           String
  cardType               String
  bps                    String?
  cnic                   String?              @unique
  status                 String               @default("Active")
  gender                 String?
  fatherName             String?
  dob                    String?
  bloodGroup             String?
  domicile               String?
  permanentAddress       String?
  presentAddress         String?
  nokName                String?
  nokRelation            String?
  nokContact             String?
  nokCnic                String?
  bankName               String?
  bankAccount            String?
  bankBranch             String?
  accountType            String?
  appointmentDate        String?
  joiningCurrentUnitDate String?
  appointmentLetterRef   String?
  joiningLetterRef       String?
  retirementDate         DateTime?
  lastPromotion          String?
  unitLocation           String?
  attachedTo             String?
  remarks                String?
  maritalStatus          String?
  religion               String?
  motherName             String?
  placeOfBirth           String?
  height                 String?
  weight                 String?
  distinguishingMarks    String?
  medicalCategory        String?
  qualification          String?
  emergencyContact       String?
  emergencyContactRelation String?
  pensionAccount         String?
  gpfAccount             String?
  domicileDistrict       String?
  languages              String?
  itSkills               String?
  nokAddress             String?
  attachedToRef          String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  attendance             Attendance[]
  disciplinaryActions    DisciplinaryAction[]
  department             Department           @relation(fields: [departmentId], references: [id])
  rank                   Rank                 @relation(fields: [rankId], references: [id])
  letters                EmployeeLetter[]
  phones                 EmployeePhone[]
  leaves                 LeaveRecord[]
  payments               Payment[]
  sanctions              Sanction[]
  workLogs               WorkLog[]
}

model Rank {
  id           String     @id @default(cuid())
  name         String     @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  bps          String?
  cadre        String?
  sanctioned   Int?       @default(0)
  bornStrength Int?       @default(0)
  employees    Employee[]
}

model Department {
  id                       String     @id @default(cuid())
  name                     String     @unique
  location                 String?
  navcom                   String?
  hodName                  String?
  hodRank                  String?
  bornStrength             Int?
  approvedSanctionStrength Int?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  employees                Employee[]
}

model EmployeePhone {
  id          String   @id @default(cuid())
  serviceNo   String
  phoneNumber String
  imei1       String?
  imei2       String?
  model       String?
  brand       String?
  employee    Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)
}

model EmployeeLetter {
  id              String   @id @default(cuid())
  serviceNo       String
  referenceNumber String
  referenceDate   DateTime
  fileName        String
  fileNumber      String
  employee        Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)
}

model Sanction {
  id         String   @id @default(cuid())
  sanctionId String   @unique
  amount     Float?
  hours      Float?
  period     String?
  reason     String?
  date       String?
  status     String   @default("Pending")
  timeline   String?  @default("[]")
  serviceNo  String
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)
}

model WorkLog {
  id        String   @id @default(cuid())
  date      DateTime
  hours     Float
  serviceNo String
  createdAt DateTime @default(now())
  employee  Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)
}

model LeaveRecord {
  id        String   @id @default(cuid())
  startDate String
  endDate   String
  type      String
  days      Int
  status    String   @default("Pending")
  timeline  String?  @default("[]")
  serviceNo String
  createdAt DateTime @default(now())
  employee  Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)
}

model DisciplinaryAction {
  id         String   @id @default(cuid())
  caseId     String   @unique
  type       String
  offense    String
  action     String
  date       String
  status     String
  remarks    String?
  reference  String?
  details    String?
  authority  String?
  serviceNo  String
  timeline   String?  @default("[]")
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  type      String
  gross     Float
  leave     Float
  payable   Float
  rate      Float
  amount    Float
  status    String
  period    String
  serviceNo String
  timeline  String?  @default("[]")
  createdAt DateTime @default(now())
  employee  Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)
}

model Attendance {
  id        String   @id @default(cuid())
  date      String
  status    String
  serviceNo String
  createdAt DateTime @default(now())
  employee  Employee @relation(fields: [serviceNo], references: [serviceNo], onDelete: Cascade)

  @@unique([date, serviceNo])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("Clerk")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Log {
  id     String   @id @default(cuid())
  time   DateTime @default(now())
  user   String
  action String
  entity String
  ip     String
  result String
}

model MusterLock {
  id       String   @id @default(cuid())
  date     String   @unique
  lockedAt DateTime @default(now())
  lockedBy String
}
